# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.

# Admin secret — used in X-Admin-Secret header for all /admin/* endpoints
ADMIN_SECRET=change-me-to-a-very-long-random-string

# Shared fallback for /node/usage reports.
# New nodes can also authenticate with their per-node NODE_SECRET.
NODE_API_SECRET=another-long-random-string-for-nodes

# Session signing secret — used to sign the admin UI browser cookie
SECRET_KEY=yet-another-long-random-string-for-sessions
