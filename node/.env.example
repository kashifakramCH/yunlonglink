# Copy to .env and fill in real values after registering this node with the central server.
# NEVER commit .env to version control.

# Central server API URL (must be reachable from this node)
CENTRAL_API_URL=https://api.yunlonglink.com

# Node ID — from the output of: python admin_cli.py add-node ...
NODE_ID=paste-node-id-here

# Node secret — from the output of: python admin_cli.py add-node ...
NODE_SECRET=paste-node-secret-here
